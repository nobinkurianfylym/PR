3.5\"><path d=\"M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4\"></path><polyline points=\"7 10 12 15 17 10\"></polyline><line x1=\"12\" x2=\"12\" y1=\"15\" y2=\"3\"></line></svg></button></div></div></div></div><!--$--><!--/$--></main><aside class=\"hidden w-80 shrink-0 border-l border-border px-6 py-8 xl:block\"><div class=\"flex items-center gap-2 text-[13px] font-medium text-muted\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sparkles h-4 w-4\"><path d=\"M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z\"></path><path d=\"M20 3v4\"></path><path d=\"M22 5h-4\"></path><path d=\"M4 17v2\"></path><path d=\"M5 18H3\"></path></svg>Campaign Brain</div><section class=\"mt-6\"><p class=\"text-[11px] font-medium uppercase tracking-[0.18em] text-faint\">Today&#x27;s recommendation</p><p class=\"mt-2 text-sm leading-relaxed\">Lock the main trailer this week. Teaser momentum peaks around day 10 — releasing the trailer inside that window compounds reach instead of restarting it.</p></section><section class=\"mt-6 rounded-xl border border-border bg-surface p-4\"><p class=\"text-[11px] font-medium uppercase tracking-[0.18em] text-faint\">Next action</p><p class=\"mt-2 text-sm leading-relaxed\">Approve trailer cut two, then schedule the drop for Friday 6pm with a street-team push in the first hour.</p><p class=\"mt-3 inline-flex items-center gap-1.5 text-[13px] font-medium\">Do it now <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right h-3.5 w-3.5\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></p></section><section class=\"mt-6\"><p class=\"text-[11px] font-medium uppercase tracking-[0.18em] text-faint\">Campaign summary</p><p class=\"mt-2 text-sm leading-relaxed text-muted\">Thira is in the Trailer phase, 33 days from release. Health is 78 and trending up: press coverage is ahead of plan, but the music phase has no confirmed dates yet — that is the biggest open risk.</p><p class=\"mt-4 text-xs text-faint\">Thira<!-- --> · <!-- -->122<!-- --> days to release</p></section></aside></div><script src=\"/_next/static/chunks/webpack-5974c4836639bfc7.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[5175,[],\\\"\\\"]\\n3:I[5115,[],\\\"\\\"]\\n4:I[7414,[\\\"873\\\",\\\"static/chunks/873-2e3382f29d22c519.js\\\",\\\"598\\\",\\\"static/chunks/598-8df30065fdf4105c.js\\\",\\\"944\\\",\\\"static/chunks/app/(app)/layout-da3311b6db55d021.js\\\"],\\\"AppShell\\\"]\\n5:I[1618,[],\\\"ClientPageRoot\\\"]\\n6:I[3025,[\\\"873\\\",\\\"static/chunks/873-2e3382f29d22c519.js\\\",\\\"125\\\",\\\"static/chunks/app/(app)/assets/page-89340b0858577174.js\\\"],\\\"default\\\"]\\n9:I[6478,[],\\\"OutletBoundary\\\"]\\nb:I[51,[],\\\"AsyncMetadataOutlet\\\"]\\nd:I[6478,[],\\\"ViewportBoundary\\\"]\\nf:I[6478,[],\\\"MetadataBoundary\\\"]\\n10:\\\"$Sreact.suspense\\\"\\n12:I[973,[],\\\"\\\"]\\n:HL[\\\"/_next/static/css/16f691357524a009.css\\\",\\\"style\\\"]\\n\"])</script><script>self.__next_f.push([1,\"0:{\\\"P\\\":null,\\\"b\\\":\\\"O8XQVddIoYPthci-mAKUA\\\",\\\"p\\\":\\\"\\\",\\\"c\\\":[\\\"\\\",\\\"assets\\\"],\\\"i\\\":false,\\\"f\\\":[[[\\\"\\\",{\\\"children\\\":[\\\"(app)\\\",{\\\"children\\\":[\\\"assets\\\",{\\\"children\\\":[\\\"__PAGE__\\\",{}]}]}]},\\\"$undefined\\\",\\\"$undefined\\\",true],[\\\"\\\",[\\\"$\\\",\\\"$1\\\",\\\"c\\\",{\\\"children\\\":[[[\\\"$\\\",\\\"link\\\",\\\"0\\\"